# ─────────────────────────────────────────────────────────────
# Variables de entorno del FRONTEND (Vite)
# Copia este archivo a .env y ajusta los valores.
# Solo las variables con prefijo VITE_ quedan expuestas al cliente.
# ─────────────────────────────────────────────────────────────

# Base URL del backend Flask.
# Déjala VACÍA en desarrollo: vite.config.js hace proxy de /api → http://localhost:5000.
# En producción, apúntala al backend desplegado (ej: https://tu-backend.onrender.com).
VITE_API_URL=

# Modo mock: si es 'true', el frontend NO llama al backend y usa respuestas
# simuladas (útil para trabajar el UI sin levantar Flask).
# Cualquier otro valor (o ausencia) => usa el API real.
VITE_USE_MOCK=false
